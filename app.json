{
  "expo": {
    "name": "SoGoJet",
    "slug": "SoGoJet",
    "version": "2.0.0",
    "scheme": "sogojet",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "description": "Two ways to find your next trip — swipe through deals or flip the departure board.",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0806"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sogojet.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0806"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.sogojet.app",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      ["expo-router", { "origin": "https://sogojet.com" }],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "updates": {
      "url": ""
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
