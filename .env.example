# ─── Supabase (database + storage) ──────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Clerk (authentication) ────────────────────────────────────────
CLERK_SECRET_KEY=your-clerk-secret-key

# ─── Travelpayouts (flight prices) ─────────────────────────────────
TRAVELPAYOUTS_TOKEN=your-travelpayouts-token
TRAVELPAYOUTS_MARKER=your-marker-id

# ─── Amadeus (optional — fallback for flight prices) ───────────────
AMADEUS_API_KEY=your-amadeus-key
AMADEUS_API_SECRET=your-amadeus-secret

# ─── LiteAPI (hotel prices) ────────────────────────────────────────
LITEAPI_API_KEY=your-liteapi-key

# ─── AI Models ─────────────────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key

# ─── Unsplash (destination images) ─────────────────────────────────
UNSPLASH_ACCESS_KEY=your-unsplash-key

# ─── Duffel (flight booking + ticketing) ───────────────────────────
DUFFEL_API_KEY=duffel_live_your-key

# ─── Stripe (payment processing) ───────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret

# ─── Resend (transactional email) ──────────────────────────────────
RESEND_API_KEY=re_your-key
RESEND_FROM_EMAIL=noreply@sogojet.com

# ─── Booking config ────────────────────────────────────────────────
BOOKING_MARKUP_PERCENT=3

# ─── Vercel (set automatically in deployments) ─────────────────────
VERCEL_ENV=development
CRON_SECRET=your-cron-secret

# ─── Optional ──────────────────────────────────────────────────────
# FRONTEND_URL=https://sogojet.com
# SENTRY_DSN=https://your-dsn@sentry.io/project-id
