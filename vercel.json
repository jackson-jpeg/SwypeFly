{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "framework": null,
  "headers": [
    {
      "source": "/assets/(.*).map",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://sogojet.com" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PATCH, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/share/:id", "destination": "/api/share/:id" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/tiktok6qw0kODSIWEj0oNE58BzKpqs3UrdPDuN.txt", "destination": "/tiktok6qw0kODSIWEj0oNE58BzKpqs3UrdPDuN.txt" },
    { "source": "/tiktok-developers-site-verification.txt", "destination": "/tiktok-developers-site-verification.txt" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap.xml" },
    { "source": "/.well-known/(.*)", "destination": "/.well-known/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/prices/refresh",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/prices/refresh-hotels",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/images/refresh",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/alerts?action=check",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/prices/refresh-calendar",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/newsletter",
      "schedule": "0 10 * * 1"
    }
  ]
}
