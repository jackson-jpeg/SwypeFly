{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "framework": null,
  "headers": [
    {
      "source": "/assets/(.*).map",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://sogojet.com" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PATCH, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://images.unsplash.com https://*.unsplash.com https://images.pexels.com https://pics.avs.io data: blob:; connect-src 'self' https://nyc.cloud.appwrite.io https://*.clerk.accounts.dev https://api.clerk.dev https://sogojet.com https://*.stripe.com; frame-ancestors 'self' https://sang3r.com https://www.sang3r.com" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/share/:id", "destination": "/api/share/:id" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/tiktok6qw0kODSIWEj0oNE58BzKpqs3UrdPDuN.txt", "destination": "/tiktok6qw0kODSIWEj0oNE58BzKpqs3UrdPDuN.txt" },
    { "source": "/tiktok-developers-site-verification.txt", "destination": "/tiktok-developers-site-verification.txt" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/prices/refresh",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/prices/refresh-hotels",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/images/refresh",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/alerts?action=check",
      "schedule": "0 8 * * *"
    }
  ]
}
